# Backend — variables de entorno (desarrollo local sin Docker).
# Copiá a `.env` y completá. NO subir el `.env` real al repo.

# Conexión a Postgres
DATABASE_URL=postgresql://prode:prode@localhost:5432/prode?schema=public

# Auth
JWT_SECRET=cambiar_por_una_cadena_larga_y_aleatoria
JWT_EXPIRES_IN=7d

PORT=4000
CORS_ORIGIN=http://localhost:3100
# URL pública del frontend (links de los mails). En prod: la de Vercel.
APP_URL=http://localhost:3100

# Datos de fútbol: openfootball (real y gratis) | api-football | static
FOOTBALL_PROVIDER=openfootball
FOOTBALL_API_URL=https://v3.football.api-sports.io
FOOTBALL_API_KEY=
RESULTS_POLL_CRON=*/5 * * * *

# Carga manual de resultados (en prod: false)
ENABLE_ADMIN_RESULTS=false

# Rate limiting
THROTTLE_LIMIT=120
AUTH_REGISTER_LIMIT=5
AUTH_LOGIN_LIMIT=10

# Email (SMTP). Vacío + MAIL_ETHEREAL=true => buzón de prueba.
MAIL_ETHEREAL=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=El Prode de la Gambeta <no-reply@tu-dominio.com>
