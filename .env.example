# ─────────────────────────────────────────────────────────────
# Variables de entorno (las consume docker-compose).
# Copiá este archivo a `.env` y completá los valores antes de levantar.
# NUNCA subas el `.env` real al repositorio (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────

# ── Postgres ──
POSTGRES_USER=prode
POSTGRES_PASSWORD=cambiar_en_produccion
POSTGRES_DB=prode
# Puerto del host (el contenedor siempre usa 5432 internamente).
POSTGRES_PORT=5433

# ── Backend ──
BACKEND_PORT=4000
# Secreto para firmar los JWT. En producción usá una cadena larga y aleatoria:
#   openssl rand -base64 48
JWT_SECRET=cambiar_por_una_cadena_larga_y_aleatoria
JWT_EXPIRES_IN=7d
# Origen(es) permitido(s) por CORS (separados por coma). En prod, tu dominio real.
CORS_ORIGIN=http://localhost:3100
# URL pública del frontend (la usan los links de los mails). En prod: la de Vercel.
APP_URL=http://localhost:3100

# ── Proveedor de datos de fútbol ──
#   openfootball = fixture y resultados reales del Mundial 2026 (gratis, sin key)
#   api-football = API-Sports (requiere plan con acceso a la temporada 2026)
#   static       = simulador offline para demo
FOOTBALL_PROVIDER=openfootball
FOOTBALL_API_URL=https://v3.football.api-sports.io
FOOTBALL_API_KEY=

# Frecuencia del job que consulta resultados (sintaxis cron).
RESULTS_POLL_CRON=*/5 * * * *

# Permite cargar resultados a mano (POST /matches/:id/result). En prod: false.
ENABLE_ADMIN_RESULTS=false

# ── Rate limiting (valores de producción) ──
THROTTLE_LIMIT=120
AUTH_REGISTER_LIMIT=5
AUTH_LOGIN_LIMIT=10

# ── Email (SMTP) ──
# Si SMTP_HOST queda vacío y MAIL_ETHEREAL=true, se usa un buzón de prueba.
# Para envíos reales, completá un proveedor SMTP (ej. Brevo, Resend, Gmail).
MAIL_ETHEREAL=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=El Prode de la Gambeta <no-reply@tu-dominio.com>

# ── Frontend ──
FRONTEND_PORT=3100
# URL pública de la API (en prod, la URL real del backend).
NEXT_PUBLIC_API_URL=http://localhost:4000
